{
  "name": "phone-mode-custom",
  "version": "1.0.0",
  "private": true,
  "description": "Build tooling for the personal Phone Mode derivative.",
  "scripts": {
    "build": "esbuild src/main.js --bundle --format=iife --platform=browser --target=es2020 --outfile=index.js --legal-comments=none",
    "check:syntax": "node --check src/main.js && node --check index.js",
    "check:contracts": "node scripts/check-contracts.mjs",
    "check": "npm run check:syntax && npm run check:contracts"
  },
  "devDependencies": {
    "acorn": "8.15.0",
    "esbuild": "0.25.12"
  }
}
